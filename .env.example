# FundX runtime environment
FUNDX_APP_ENV=development
FUNDX_BASE_URL=http://localhost:3000
FUNDX_CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
VITE_API_BASE_URL=

# Local JSON database runtime paths
FUNDX_DATA_DIR=data
FUNDX_DB_FILE=data/fundx.db.json
FUNDX_BACKUP_DIR=backups
FUNDX_BACKUP_RETENTION_DAYS=14

# User data persistence
# browser-local keeps portfolios, calculations, histories, reports, watchlists,
# saved plans, and settings in browser storage. Use server only for private
# deployments that intentionally persist user data in the backend DB.
FUNDX_USER_DATA_MODE=browser-local

# Logs and health checks
FUNDX_LOG_DIR=logs
FUNDX_LOG_LEVEL=info
FUNDX_SLOW_QUERY_MS=500
FUNDX_HEALTH_MAX_BACKUP_AGE_HOURS=24
FUNDX_REQUIRE_RECENT_BACKUP=false

# Background job monitor state
FUNDX_RUNTIME_DIR=.fundx-runtime
FUNDX_JOB_HEARTBEAT_MS=15000
FUNDX_JOB_STALE_MS=300000

# Market data providers.
# Keep real keys in .env.local or the deployment secret store, not in git.
FUNDX_MARKET_DATA_PROVIDER=public-no-key
FUNDX_MARKET_DATA_PROVIDERS=
FUNDX_MARKET_DATA_CIRCUIT_THRESHOLD=3
FUNDX_MARKET_DATA_CIRCUIT_COOLDOWN_SECONDS=300
FUNDX_LIVE_MARKET_DATA=false
FUNDX_MARKET_DATA_API_KEY=
FUNDX_US_MARKET_DATA_API_KEY=
FUNDX_TUSHARE_TOKEN=
FUNDX_TDX_HOST=119.147.212.81
FUNDX_TDX_PORT=7709
FUNDX_TICKFLOW_API_KEY=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
LONGBRIDGE_REGION=

# Optional future alert target for scheduled monitors.
FUNDX_ALERT_WEBHOOK_URL=
